{
  "name": "Milk Farm Monthly Bill Calculator",
  "short_name": "MILK Bill",
  "description": "Comprehensive bill calculator and management tool for milk farm customers. Supports quick billing, multi-shift data entry (Morning/Evening), data backup, and cloud storage functionality.",
  "id": "/MILK-APP/",
  "start_url": "/MILK/",
  "scope": "/MILK/",
  "display": "standalone",
  "orientation": "portrait",
  "background_color": "#ffffff",
  "theme_color": "#4A90E2",
  "lang": "te",
  "dir": "auto",

  "icons": [
    {
      "src": "images/android-launchericon-48-48.png",
      "sizes": "48x48",
      "type": "image/png"
    },
    {
      "src": "images/android-launchericon-192-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "images/android-launchericon-512-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  
  "shortcuts": [
    {
      "name": "Quick Add Record",
      "short_name": "Quick Add",
      "description": "Quickly add records for multiple customers.",
      "url": "/MILK/?quick_add=1",
      "icons": [
        {
          "src": "images/android-launchericon-96-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Customer Bills",
      "short_name": "View Bills",
      "description": "Go to the list of all registered customers.",
      "url": "/MILK/?view_customers=1",
      "icons": [
        {
          "src": "images/android-launchericon-96-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],

  "display_override": [
    "window-controls-overlay",
    "fullscreen",
    "tabbed" 
  ],

  "categories": [
    "productivity",
    "finance",
    "business"
  ],

  "screenshots": [
    {
      "src": "images/screenshot-mobile.png",
      "sizes": "426x761",
      "type": "image/png",
      "form_factor": "narrow"
    },
    {
      "src": "images/screenshot-desktop.png",
      "sizes": "1280x800",
      "type": "image/png",
      "form_factor": "wide"
    }
  ],

  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.bheemezh.milk",
      "id": "com.bheemezh.milk"
    }
  ],
  "prefer_related_applications": false, 

  "iarc_rating_id": "93693245-c8b5-4148-9c59-b1d3d63e9f33",
  
  "scope_extensions": [
    {
      "origin": "https://api.bheemezh.github.io"
    }
  ],

  "launch_handler": {
    "client_mode": "navigate-existing" 
  },

  "file_handlers": [
    {
      "action": "/MILK/import-data",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".milkdata"]
      }
    }
  ],

  "share_target": {
    "action": "/MILK/share-data",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "widgets": [
    {
      "name": "Quick Entry",
      "description": "Add milk entries quickly without opening the main app.",
      "tag": "milk_entry_widget",
      "template": "widgets/quick-entry-template.json",
      "ms_edge_side_panel": {
        "url": "/MILK/widgets/quick-entry.html"
      }
    }
  ],

  "note_taking": {
    "new_note_url": "/MILK/new-customer"
  },

  "protocol_handlers": [
    {
      "protocol": "web+milk",
      "url": "/MILK/app?record=%s"
    }
  ]
}